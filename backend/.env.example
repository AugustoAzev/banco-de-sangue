# Database type: 'mysql' or 'postgresql'
DB_TYPE=mysql

# MySQL settings (used when DB_TYPE=mysql)
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=banco_sangue

# PostgreSQL settings (used when DB_TYPE=postgresql)
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_HOST=seu-host.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres

# Supabase (PostgreSQL via pooler - recomendado)
# DB_TYPE=postgresql
# DB_HOST=aws-0-xx.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.xxxxxxxxxxxx
# DB_PASSWORD=sua_senha
# DB_DATABASE=postgres

# JWT secret key
SECRET_KEY=sua_chave_secreta_aqui
